# GoPhish MCP Server Configuration
# Copy this file to .env and update with your actual values

# GoPhish Server Configuration
GOPHISH_URL=https://localhost:3333
GOPHISH_API_KEY=your-api-key-here

# SSL Configuration (for development)
GOPHISH_VERIFY_SSL=false

# Optional: Custom timeout settings
GOPHISH_TIMEOUT=30

# Optional: Debug mode
GOPHISH_DEBUG=false
